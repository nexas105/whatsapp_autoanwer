# Server
PORT=3000
HOST=127.0.0.1

# SQLite DB file
DB_PATH=./data/app.db

# whatsapp-web.js session storage
WWEBJS_AUTH_DIR=./data/.wwebjs_auth

# AI CLI wrapper — invoked as: $AI_CLI_CMD $AI_CLI_ARGS (args are a JSON array).
# Prompt is delivered via stdin or as last arg, controlled by AI_CLI_PROMPT_MODE.
#
# Examples:
#   claude CLI (recommended; sonnet, no tools, no session persistence):
#     AI_CLI_CMD=claude
#     AI_CLI_ARGS=["-p","--tools","","--no-session-persistence","--model","sonnet"]
#     AI_CLI_PROMPT_MODE=stdin
#
#   codex CLI:   AI_CLI_CMD=codex   AI_CLI_ARGS=["exec","--quiet"]   AI_CLI_PROMPT_MODE=arg
#   mock (dev):  AI_CLI_CMD=mock    AI_CLI_ARGS=[]                   AI_CLI_PROMPT_MODE=stdin
AI_CLI_CMD=claude
AI_CLI_ARGS=["-p","--tools","","--no-session-persistence","--model","sonnet"]
AI_CLI_PROMPT_MODE=stdin
AI_CLI_TIMEOUT_MS=120000

# Auto-reply defaults
DEFAULT_AUTO_REPLY=false
DEFAULT_REPLY_DELAY_MS=15000
DEFAULT_CONTEXT_MESSAGES=20

# Voice transcription (whisper.cpp + ffmpeg).
# brew install whisper-cpp ffmpeg
# Download a model into data/models/, e.g.
#   curl -L https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3-turbo.bin \
#     -o data/models/ggml-large-v3-turbo.bin
WHISPER_BIN=whisper-cli
FFMPEG_BIN=ffmpeg
WHISPER_MODEL=./data/models/ggml-large-v3-turbo.bin
WHISPER_LANG=auto
WHISPER_THREADS=8
TRANSCRIBE_AUTO=true
TRANSCRIBE_TIMEOUT_MS=180000

# Image analysis (vision) — uses the same claude CLI but with the Read tool.
# Fires automatically on every incoming image and stores a short German
# description on the message (same column as voice transcripts).
VISION_AUTO=true
VISION_TIMEOUT_MS=90000

# Dashboard authentication. Empty/unset = no auth (local-only setups).
# When set, all /api/* and /ws requests require Authorization: Bearer <token>.
# The web UI prompts on first load and stores the value in localStorage.
DASHBOARD_TOKEN=
